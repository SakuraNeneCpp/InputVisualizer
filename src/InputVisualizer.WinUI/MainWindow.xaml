<Window
    x:Class="InputVisualizer.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="InputVisualizer">

    <Grid Padding="24" Background="#101010" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock
                FontSize="24"
                FontWeight="SemiBold"
                Foreground="#F5F5F5"
                Text="InputVisualizer" />
            <TextBlock
                Foreground="#BDBDBD"
                Text="Safe input overlay for Windows streaming" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock
                    x:Name="StatusTextBlock"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="#FFFFFF"
                    Text="Input hidden: overlay disabled" />
                <TextBlock
                    x:Name="ForegroundTextBlock"
                    Foreground="#BDBDBD"
                    Text="Foreground process: unknown" />
                <TextBlock
                    x:Name="ModeTextBlock"
                    Foreground="#BDBDBD"
                    Text="Mode: action" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Click="EnableButton_Click" Content="Enable" />
                <Button Click="PauseButton_Click" Content="Pause" />
                <Button Click="ResumeButton_Click" Content="Resume" />
                <Button Click="PanicButton_Click" Content="Panic" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="2"
            Padding="16"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Foreground="#DADADA"
                    FontWeight="SemiBold"
                    Text="Overlay Preview" />

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
                    <StackPanel
                        x:Name="ActionPanel"
                        MinHeight="80"
                        Orientation="Horizontal"
                        Spacing="8" />
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button Click="LeaveTextModeButton_Click" Content="Leave text mode" />
            <Button Click="ResetPanicButton_Click" Content="Reset panic" />
        </StackPanel>
    </Grid>
</Window>
